# Normalize line endings: LF in the repo for source files, CRLF for Windows
# batch shims (which are launched by cmd.exe).
* text=auto
*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.cmd  text eol=crlf

# Binary assets — never normalize line endings on these (vendored brand assets).
*.ttf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
